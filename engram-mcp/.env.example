# ==================== Database ====================
POSTGRES_USER=app
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=appdb

# ==================== Redis ====================
REDIS_PASSWORD=redis_password

# ==================== RabbitMQ ====================
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ==================== LiteLLM ====================
LITELLM_MASTER_KEY=litellm_key_123

# ==================== Engram MCP ====================
DATABASE_URL=postgresql+asyncpg://app:postgres_password@postgres:5432/appdb
REDIS_URL=redis://:redis_password@redis:6379/0
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
LITELLM_BASE_URL=http://litellm:4000
LITELLM_API_KEY=litellm_key_123
LITELLM_EMBED_MODEL=text-embedding-3-small
LITELLM_CHAT_MODEL=gpt-4o-mini

APP_HOST=0.0.0.0
APP_PORT=8001
NAMESPACE=default
